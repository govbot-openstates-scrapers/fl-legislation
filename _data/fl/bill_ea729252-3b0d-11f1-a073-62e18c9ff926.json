{"legislative_session": "2026", "identifier": "SB 484", "title": "Data Centers", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["public business", "public officers, employees, and records", "railroads and other regulated utilities", "reclamation, and use", "relations"], "abstracts": [{"note": "summary", "abstract": "Data Centers;  Specifying that local governments maintain authority to exercise power and responsibility over comprehensive planning and land development regulations relating to large load customers; requiring public utilities to provide certain minimum tariff and service requirements for large load customers; prohibiting the governing board of a water management district or the Department of Environmental Protection from issuing a permit for the consumptive use of water to a large-scale data center under certain circumstances; requiring the Office of Program Policy Analysis and Government Accountability to contract for a study relating to the construction and operation of large-scale data centers, etc."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-fl-2026-sb484"}], "actions": [{"description": "Filed", "date": "2026-01-09", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["filing"], "related_entities": []}, {"description": "Referred to Regulated Industries; Community Affairs; Rules", "date": "2026-01-12", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "Introduced", "date": "2026-01-13", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "On Committee agenda-- Regulated Industries, 01/20/26, 9:30 am, 412 Knott Building", "date": "2026-01-15", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Favorable by Regulated Indust