{"legislative_session": "2026", "identifier": "SB 1332", "title": "Career Offender Registration", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["crimes", "criminal procedure and corrections", "motor vehicles"], "abstracts": [{"note": "summary", "abstract": "Career Offender Registration;  Requiring a certain driver license or identification card marking for a career offender; requiring a career offender to report to the Department of Highway Safety and Motor Vehicles in a certain month to obtain an updated or renewed driver license or identification card; providing that if a sanction is not imposed upon a career offender, such offender is deemed to have been released upon conviction; requiring certain career offenders to report to the Department of Highway Safety and Motor Vehicles and obtain a driver license or identification card containing a required marking within a certain period of time; authorizing the Department of Highway Safety and Motor Vehicles to release certain images to the Department of Law Enforcement for purposes of public notification, etc."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-fl-2026-sb1332"}], "actions": [{"description": "Filed", "date": "2026-01-07", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["filing"], "related_entities": []}, {"description": "Referred to Criminal Justice; Appropriations Committee on Criminal and Civil Justice; Fiscal Policy", "date": "2026-01-16", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "On Committee agenda-- Criminal Justice, 01/26/26, 3:30 pm, 37 Senate Building", "date": "2026-01-21", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Introduced", "date": "2026-01-22", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["intr